DATABASE_URL="file:./dev.db"
# SQLite remains the default local profile.
# For the Postgres profile, use `.env.postgres.example` or replace with:
# DATABASE_URL="postgresql://readar:readar@localhost:5432/news_feed_agent?schema=public"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
USE_REMOTE_RSS="true"
USE_OPENAI_SUMMARIES="false"
REFRESH_INTERVAL_MINUTES="180"
RUN_LOCK_WINDOW_MINUTES="15"
STALE_RUN_MINUTES="30"
CRON_SECRET="replace-me-for-scheduled-refreshes"
OPS_ALERT_PROVIDER="generic"
OPS_ALERT_WEBHOOK_URL=""
AUTH_USERNAME="owner"
AUTH_PASSWORD="readar-demo"
AUTH_DISPLAY_NAME="ReadAR Owner"
