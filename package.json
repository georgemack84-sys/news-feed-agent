{
  "name": "news-feed-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate:postgres": "prisma generate --schema prisma/postgres/schema.prisma",
    "db:migrate:postgres": "prisma migrate deploy --schema prisma/postgres/schema.prisma",
    "db:seed:postgres": "tsx prisma/seed-postgres.ts",
    "db:switch:postgres": "powershell -ExecutionPolicy Bypass -File scripts/switch-to-postgres.ps1",
    "deploy:check": "tsx scripts/checkDeploymentReadiness.ts",
    "feed:refresh": "tsx scripts/refreshFeeds.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "dotenv": "^17.3.1",
    "next": "^16.2.0",
    "openai": "^6.32.0",
    "prisma": "^6.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^20.17.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2"
  }
}
